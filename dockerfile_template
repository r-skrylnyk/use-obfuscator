# Dockerfile Template — use-obfuscator
#
# Замініть значення в кутових дужках <...> на свої.
# Цей шаблон замінює старий підхід з obscure@1.0.1 + патч index.js.
#
# Відмінності від старого obscure:
#   - НЕ потрібен COPY assets/obscure/index.js (патч більше не потрібен)
#   - exclude задається файлом --exclude-list, не хардкодом у пакеті
#   - карта обфускації: use-obfuscator.map.json (було: obscure.map)
#   - підтримує .php, .vue, .jsx, .tsx, glob, конфіг-файл
#
# ВАЖЛИВО: Потрібен Node.js >= 20.18.1
#   use-obfuscator залежить від cheerio@1.x який тягне undici@7.x.
#   undici@7.x не працює на Node 18 (ReferenceError: File is not defined).
#   Використовуйте node:20 або новіше.
#
# Перед використанням:
#   1. Додайте exclude-classes.json у корінь сайту (див. нижче)
#   2. Замініть <YOUR_DOCKERHUB_USER>/<YOUR_IMAGE_NAME> на своє
# ─────────────────────────────────────────────────────────────────────────────

FROM node:20-bookworm-slim AS builder

# --- Системні утиліти (ті самі що були у вас) --------------------------------
RUN apt-get update && \
    apt-get install -y \
        tree \
        rsync \
        ssh-client \
    && rm -rf /var/lib/apt/lists/*

# --- Встановити use-obfuscator глобально ------------------------------------
RUN npm install -g use-obfuscator@1.0.1

WORKDIR /app
COPY . .

RUN mkdir -p /output/dist

# --- Діагностика (можна прибрати після першого успішного білду) --------------
RUN node -v && npm -v
RUN use-obfuscator --version

# --- Запуск обфускації -------------------------------------------------------
#
# --exclude-list exclude-classes.json
#   Список класів які НЕ треба обфускувати (bootstrap, js-хуки тощо).
#   Файл лежить у корені вашого сайту.
#   Формат JSON: ["navbar","active","show","collapse",...]
#
# --seed 42
#   Фіксований seed → однаковий результат при кожному білді.
#   Якщо прибрати --seed → кожен білд дає нові назви класів (менш бажано).
#
# Якщо треба обфускувати кілька HTML файлів:
#   --apply "index.html,about.html,partials/*.php"
#
RUN use-obfuscator style.css \
        --apply index.html \
        --exclude-list exclude-classes.json \
        --output /output/dist \
        --seed 42 \
    || (echo "[ERROR] use-obfuscator failed" && exit 1)

# --- Копіювати решту файлів сайту --------------------------------------------
#     Налаштуйте список папок і файлів під свій проєкт
RUN set -ex && \
    cp -vR \
        assets/ \
        fonts/ \
        wall/ \
        /output/dist/ 2>/dev/null || true && \
    cp -v \
        english.js \
        fonts.css \
        robots.txt \
        /output/dist/ 2>/dev/null || true

RUN chmod -R 755 /output/dist

# ─── Stage 2: фінальний мінімальний образ ────────────────────────────────────
FROM alpine:3.18
COPY --from=builder /output/dist /dist


